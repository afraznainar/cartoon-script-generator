# ── Supabase Edge Function secrets (set via `supabase secrets set`) ──
# These must be set as secrets in your Supabase Edge Function
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxx

# ── Browser settings (entered via the gear icon in the app) ──
# These are stored in localStorage on the client side
# SUPABASE_URL = same as above
# SUPABASE_ANON_KEY = same as above
# EDGE_FUNCTION_URL = https://[PROJECT_REF].supabase.co/functions/v1/generate-script
